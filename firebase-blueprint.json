{
  "entities": {
    "UserProfile": {
      "title": "UserProfile",
      "description": "User's public and private profile data for dating and matchmaking.",
      "type": "object",
      "properties": {
        "name": {
          "type": "string",
          "maxLength": 100,
          "description": "User's display name"
        },
        "age": {
          "type": "integer",
          "description": "User's age"
        },
        "gender": {
          "type": "string",
          "maxLength": 50,
          "description": "User's gender"
        },
        "interests": {
          "type": "array",
          "description": "List of user interests"
        },
        "photos": {
          "type": "array",
          "description": "List of profile picture URLs (or base64 strings)"
        },
        "location": {
          "type": "string",
          "maxLength": 100,
          "description": "User's location"
        },
        "profession": {
          "type": "string",
          "maxLength": 100,
          "description": "User's profession"
        },
        "bio": {
          "type": "string",
          "maxLength": 1000,
          "description": "User's bio description"
        },
        "updatedAt": {
          "type": "string",
          "description": "Timestamp of last edit"
        }
      },
      "required": ["name", "age", "gender"]
    }
  },
  "firestore": {
    "users/{userId}": {
      "schema": "UserProfile",
      "description": "Collection of user profiles keyed by user auth UID."
    },
    "matches/{matchId}": {
      "schema": "Match",
      "description": "Collection of matches between users."
    },
    "messages/{messageId}": {
      "schema": "Message",
      "description": "Collection of direct messages sent between matched users."
    }
  }
}
